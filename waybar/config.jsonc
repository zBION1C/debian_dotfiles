{
	"layer": "top",
	"position": "top",

	"modules-left": [
		"niri/workspaces",
        "niri/window"
	],

    "modules-center": [
        "network"
    ],
        
	"modules-right": [
		"tray",
		"clock#time"
	],

    "network": { 
        "family": "ipv4",
        "format": "󰈀 {ipaddr}/{cidr}"
    },

    "tray": {
        "icon-size": 21,
        "spacing": 10
    }
}
